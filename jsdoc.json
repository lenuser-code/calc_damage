{
    "plugins": [
        "plugins/markdown"
    ],
    "source": {
        "include": ["calc_damage_rewrite.js"],
        "exclude": ["node_modules"]
    },
    "markdown": {
        "hardwrap": false,
        "idInHeadings": true
    },
    "opts": {
        "readme": "README.md",  // これを追加
        "destination": "./docs",
        "recurse": true,
        "template": "node_modules/better-docs"
    }
}
